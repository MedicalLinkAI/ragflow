# RAGflow dev 环境配置 — 1xxxx 端口段
DEPLOY_ENV=dev
COMPOSE_PROJECT_NAME=ragflow-dev

# --- 镜像 ---
RAGFLOW_IMAGE=registry.cn-hangzhou.aliyuncs.com/infiniflow/ragflow:v0.24.0
DB_TYPE=postgres
API_PROXY_SCHEME=python

# --- Elasticsearch ---
STACK_VERSION=8.11.3
ES_HOST=ragflow-dev-elasticsearch
ES_PORT=9200
ES_HOST_PORT=11200
ELASTIC_PASSWORD=infini_rag_flow
ES_MEM_LIMIT=4294967296

# --- PostgreSQL (NOT MySQL) ---
POSTGRES_HOST=ragflow-dev-postgres
POSTGRES_PORT=5432
POSTGRES_HOST_PORT=15455
POSTGRES_USER=rag_flow
POSTGRES_PASSWORD=infini_rag_flow
POSTGRES_DBNAME=rag_flow

# --- Redis (Valkey) ---
REDIS_HOST=ragflow-dev-redis
REDIS_PORT=6379
REDIS_HOST_PORT=16379
REDIS_PASSWORD=infini_rag_flow

# --- MinIO ---
MINIO_HOST=ragflow-dev-minio
MINIO_PORT=9000
MINIO_HOST_PORT=19000
MINIO_CONSOLE_PORT=9001
MINIO_CONSOLE_HOST_PORT=19001
MINIO_USER=rag_flow
MINIO_PASSWORD=infini_rag_flow

# --- Worker ---
HF_ENDPOINT=https://hf-mirror.com
KMP_DUPLICATE_LIB_OK=True
KMP_INIT_AT_FORK=FALSE
TOKENIZERS_PARALLELISM=false
PYTHONPATH=/ragflow

# --- GPU ---
GPU_ENABLED=false

# --- 宿主机端口 ---
RAGFLOW_API_HOST_PORT=19380
RAGFLOW_WEB_HOST_PORT=18080

# --- 数据存储 ---
DATA_ROOT=./data
