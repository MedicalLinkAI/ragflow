# =============================================================================
# RAGflow 容器化部署 — 环境变量模板
# =============================================================================
# 使用方法：复制为 .env 并按需修改
#   cp .env.example .env
#
# 安全警告：生产环境务必替换所有默认密码！
#   生成随机密码: openssl rand -hex 32
# =============================================================================

# -----------------------------------------------------------------------------
# 部署环境标识
# -----------------------------------------------------------------------------
DEPLOY_ENV=dev                            # dev | staging | prod
COMPOSE_PROJECT_NAME=ragflow-dev          # compose 项目名，影响容器前缀

# -----------------------------------------------------------------------------
# RAGflow 主镜像
# -----------------------------------------------------------------------------
RAGFLOW_IMAGE=ragflow:dev
NEED_MIRROR=0
# 可选镜像源:
#   infiniflow/ragflow:v0.24.0                                   # Docker Hub
#   swr.cn-north-4.myhuaweicloud.com/infiniflow/ragflow:v0.24.0  # 华为云

# DB 类型: postgres | mysql (我们使用 postgres)
DB_TYPE=postgres

# API 代理模式: python | golang | hybrid
API_PROXY_SCHEME=python

# -----------------------------------------------------------------------------
# Elasticsearch
# -----------------------------------------------------------------------------
STACK_VERSION=8.11.3                      # ES 版本
ES_HOST=ragflow-dev-elasticsearch         # ES 容器名 (compose 内部)
ES_PORT=9200                              # ES 容器内部端口
ES_HOST_PORT=11200                        # 宿主机映射端口 (dev: 1xxxx)
ELASTIC_PASSWORD=infini_rag_flow          # ⚠️ 生产环境必须修改
ES_MEM_LIMIT=4294967296                   # ES JVM 堆内存 (4GB)

# -----------------------------------------------------------------------------
# PostgreSQL (NOT MySQL — RAGflow 默认 MySQL，我们显式使用 PG)
# -----------------------------------------------------------------------------
POSTGRES_HOST=ragflow-dev-postgres        # PG 容器名
POSTGRES_PORT=5432                        # PG 容器内部端口
POSTGRES_HOST_PORT=15455                  # 宿主机映射端口
POSTGRES_USER=rag_flow                    # ⚠️ 生产环境建议修改
POSTGRES_PASSWORD=infini_rag_flow         # ⚠️ 生产环境必须修改
POSTGRES_DBNAME=rag_flow

# -----------------------------------------------------------------------------
# Redis / Valkey
# -----------------------------------------------------------------------------
REDIS_HOST=ragflow-dev-redis              # Redis 容器名
REDIS_PORT=6379                           # 容器内部端口
REDIS_HOST_PORT=16379                     # 宿主机映射端口
REDIS_PASSWORD=infini_rag_flow            # ⚠️ 生产环境必须修改

# -----------------------------------------------------------------------------
# MinIO (对象存储)
# -----------------------------------------------------------------------------
MINIO_HOST=ragflow-dev-minio              # MinIO 容器名
MINIO_PORT=9000                           # API 端口 (容器内部)
MINIO_HOST_PORT=19000                     # API 宿主机映射端口
MINIO_CONSOLE_PORT=9001                   # Console 端口 (容器内部)
MINIO_CONSOLE_HOST_PORT=19001             # Console 宿主机映射端口
MINIO_USER=rag_flow                       # ⚠️ 生产环境建议修改
MINIO_PASSWORD=infini_rag_flow            # ⚠️ 生产环境必须修改

# -----------------------------------------------------------------------------
# Worker 环境变量 (task_executor 专用)
# -----------------------------------------------------------------------------
HF_ENDPOINT=https://hf-mirror.com        # HuggingFace 镜像 (国内加速)
KMP_DUPLICATE_LIB_OK=True
KMP_INIT_AT_FORK=FALSE
TOKENIZERS_PARALLELISM=false
PYTHONPATH=/ragflow

# -----------------------------------------------------------------------------
# GPU 配置
# -----------------------------------------------------------------------------
GPU_ENABLED=false                         # true 启用 GPU
GPU_DEVICES=all                           # GPU 设备 (all / 0 / 0,1 等)

# -----------------------------------------------------------------------------
# 宿主机端口 — RAGflow 应用
# -----------------------------------------------------------------------------
RAGFLOW_API_HOST_PORT=19380               # ragflow-api 对外端口
RAGFLOW_WEB_HOST_PORT=18080               # ragflow-web (nginx) 对外端口

# -----------------------------------------------------------------------------
# 数据存储根目录 (ES/PG/MinIO bind mount)
# -----------------------------------------------------------------------------
DATA_ROOT=./data

# =============================================================================
# 宿主机端口汇总表 (dev 环境 1xxxx 段)
# =============================================================================
# | 服务                | 容器端口 | 宿主机端口       | 变量                     |
# |---------------------|----------|------------------|--------------------------|
# | Elasticsearch       | 9200     | ES_HOST_PORT     | 11200                    |
# | PostgreSQL          | 5432     | POSTGRES_HOST_PORT| 15455                   |
# | Redis (Valkey)      | 6379     | REDIS_HOST_PORT  | 16379                    |
# | MinIO API           | 9000     | MINIO_HOST_PORT  | 19000                    |
# | MinIO Console       | 9001     | MINIO_CONSOLE_HOST_PORT | 19001             |
# | RAGflow API         | 9380     | RAGFLOW_API_HOST_PORT | 19380              |
# | RAGflow Web         | 80       | RAGFLOW_WEB_HOST_PORT | 18080              |
# =============================================================================
