# 116 test draft
# RAGflow test 环境配置 — 2xxxx/29xxx 端口段
DEPLOY_ENV=test
COMPOSE_PROJECT_NAME=ragflow-test

# --- 镜像 ---
RAGFLOW_IMAGE=ragflow:test
RAGFLOW_WEB_IMAGE=ragflow-web:test
NEED_MIRROR=1
DB_TYPE=postgres
API_PROXY_SCHEME=python

# --- Elasticsearch ---
STACK_VERSION=8.11.3
ES_HOST=ragflow-test-elasticsearch
ES_PORT=9200
ES_HOST_PORT=21210
ELASTIC_PASSWORD=infini_rag_flow
ES_MEM_LIMIT=4294967296

# --- PostgreSQL (NOT MySQL) ---
POSTGRES_HOST=ragflow-test-postgres
POSTGRES_PORT=5432
POSTGRES_HOST_PORT=25455
POSTGRES_USER=rag_flow
POSTGRES_PASSWORD=infini_rag_flow
POSTGRES_DBNAME=rag_flow

# --- Redis (Valkey) ---
REDIS_HOST=ragflow-test-redis
REDIS_PORT=6379
REDIS_HOST_PORT=26379
REDIS_PASSWORD=infini_rag_flow

# --- MinIO ---
MINIO_HOST=ragflow-test-minio
MINIO_PORT=9000
MINIO_HOST_PORT=29000
MINIO_CONSOLE_PORT=9001
MINIO_CONSOLE_HOST_PORT=29001
MINIO_USER=rag_flow
MINIO_PASSWORD=infini_rag_flow

# --- Worker ---
HF_ENDPOINT=https://hf-mirror.com
KMP_DUPLICATE_LIB_OK=True
KMP_INIT_AT_FORK=FALSE
TOKENIZERS_PARALLELISM=false
PYTHONPATH=/ragflow

# --- GPU ---
GPU_ENABLED=false

# --- 宿主机端口 ---
RAGFLOW_API_HOST_PORT=29380
RAGFLOW_WEB_HOST_PORT=29381

# --- Callback ---
SYNC_CALLBACK_URL=http://medlinkai-test-callback:8000/api/v1/sync/chunks
